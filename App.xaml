<Application
    x:Class="AMD.BootCamp.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="NanumRegular">ms-appx:///Assets/Fonts/NanumSquareNeo-bRg.ttf#나눔스퀘어 네오 Regular</FontFamily>
            <FontFamily x:Key="NanumLight">ms-appx:///Assets/Fonts/NanumSquareNeo-aLt.ttf#나눔스퀘어 네오 Light</FontFamily>
            <FontFamily x:Key="NanumBold">ms-appx:///Assets/Fonts/NanumSquareNeo-cBd.ttf#나눔스퀘어 네오 Bold</FontFamily>
            <FontFamily x:Key="NanumExtraBold">ms-appx:///Assets/Fonts/NanumSquareNeo-dEb.ttf#나눔스퀘어 네오 ExtraBold</FontFamily>
            <FontFamily x:Key="NanumHeavy">ms-appx:///Assets/Fonts/NanumSquareNeo-eHv.ttf#나눔스퀘어 네오 Heavy</FontFamily>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource NanumExtraBold}" />
                <Setter Property="FontSize" Value="30" />
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource NanumBold}" />
                <Setter Property="FontSize" Value="20" />
            </Style>
            <Style x:Key="CaptionStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource NanumRegular}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Opacity" Value="0.68" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="#0A000000" />
                <Setter Property="BorderBrush" Value="#22000000" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="20" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
